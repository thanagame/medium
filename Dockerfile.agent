FROM jenkins/inbound-agent:latest-jdk21

USER root

RUN apt-get update && apt-get install -y \
    curl ca-certificates gnupg lsb-release git \
    && rm -rf /var/lib/apt/lists/*

# Docker CLI (agent เป็นคน build/push image จริง ผ่าน docker.sock ที่ mount เข้ามา)
RUN curl -fsSL https://download.docker.com/linux/debian/gpg | gpg --dearmor -o /usr/share/keyrings/docker-archive-keyring.gpg && \
    echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] https://download.docker.com/linux/debian $(lsb_release -cs) stable" > /etc/apt/sources.list.d/docker.list && \
    apt-get update && apt-get install -y docker-ce-cli && \
    rm -rf /var/lib/apt/lists/*

# Node 22 + pnpm ผ่าน corepack (ตรงกับ engines ของโปรเจกต์นี้)
RUN curl -fsSL https://deb.nodesource.com/setup_22.x | bash - && \
    apt-get install -y nodejs && \
    corepack enable && \
    corepack prepare pnpm@10.25.0 --activate

# 🔧 รับ GID จากภายนอกตอน build แทนการ hard-code (กัน GID mismatch เวลาย้ายเครื่อง)
ARG DOCKER_GID=999
RUN groupadd -f -g ${DOCKER_GID} docker || groupmod -g ${DOCKER_GID} docker
RUN usermod -aG docker jenkins

